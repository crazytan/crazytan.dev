---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = (await getCollection('projects')).sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Base>
    <header class="header">
        <div class="prompt">~ $ whoami<span class="cursor"></span></div>
        <h1>crazytan</h1>
        <p class="tagline">Security engineer. Building things that respect your privacy.</p>

        <div class="links">
            <a href="https://github.com/crazytan" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                github
            </a>
            <a href="https://x.com/_crazytan" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                @_crazytan
            </a>
            <a href="https://linkedin.com/in/crazytan" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                linkedin
            </a>
            <a href="#" class="email-obf" data-e="dGp0YW5qaWEudGFuQGdtYWlsLmNvbQ==" title="Click to reveal">
                <svg viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
                <span>email</span>
            </a>
        </div>
    </header>

    <section class="section">
        <div class="section-title">// projects</div>
        {projects.map((project) => (
            <ProjectCard
                title={project.data.title}
                url={project.data.url}
                description={project.data.description}
                tags={project.data.tags}
                badges={project.data.badges}
            />
        ))}
    </section>

    <footer class="footer">
        built with stubbornness and too much coffee ☕
    </footer>
</Base>

<script>
    document.querySelector('.email-obf')?.addEventListener('click', function(e) {
        e.preventDefault();
        const el = this as HTMLAnchorElement;
        const encoded = el.dataset.e;
        if (encoded) {
            const email = atob(encoded);
            el.href = 'mailto:' + email;
            const span = el.querySelector('span');
            if (span) span.textContent = email;
            delete el.dataset.e;
            el.removeEventListener('click', arguments.callee as EventListener);
        }
    });
</script>

<style>
    .header {
        margin-bottom: 48px;
    }

    .prompt {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.85em;
        color: var(--text-dim);
        margin-bottom: 12px;
    }

    .prompt .cursor {
        display: inline-block;
        width: 8px;
        height: 16px;
        background: var(--accent);
        margin-left: 4px;
        animation: blink 1s step-end infinite;
        vertical-align: text-bottom;
    }

    @keyframes blink { 50% { opacity: 0; } }

    h1 {
        font-size: 2.2em;
        font-weight: 600;
        letter-spacing: -0.03em;
        margin-bottom: 8px;
    }

    .tagline {
        font-size: 1.1em;
        color: var(--text-dim);
        line-height: 1.5;
    }

    .links {
        display: flex;
        gap: 20px;
        margin-top: 20px;
        flex-wrap: wrap;
    }

    .links a {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.85em;
        color: var(--text-dim);
        text-decoration: none;
        transition: color 0.2s;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .links a:hover { color: var(--accent); }

    .links a svg {
        width: 16px;
        height: 16px;
        fill: currentColor;
    }

    .section {
        margin-top: 48px;
    }

    .section-title {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8em;
        color: var(--text-dim);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 16px;
        padding-bottom: 8px;
        border-bottom: 1px solid var(--border);
    }

    .footer {
        margin-top: 64px;
        padding-top: 20px;
        border-top: 1px solid var(--border);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75em;
        color: var(--text-dim);
    }

    @media (max-width: 480px) {
        h1 { font-size: 1.8em; }
        .links { gap: 16px; }
    }
</style>
