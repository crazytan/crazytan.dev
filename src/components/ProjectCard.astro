---
interface Badge {
  text: string;
  type: 'live' | 'oss';
  url?: string;
}

interface Props {
  title: string;
  url: string;
  description: string;
  tags: string[];
  badges: Badge[];
}

const { title, url, description, tags, badges } = Astro.props;
---

<div class="project">
    <div class="project-header">
        <span class="project-name"><a href={url}>{title}</a></span>
        <div style="display:flex;gap:6px;">
            {badges.map((badge) =>
                badge.url ? (
                    <a href={badge.url} target="_blank" rel="noopener" style="text-decoration:none">
                        <span class={`badge badge-${badge.type}`}>{badge.text}</span>
                    </a>
                ) : (
                    <span class={`badge badge-${badge.type}`}>{badge.text}</span>
                )
            )}
        </div>
    </div>
    <p class="project-desc">{description}</p>
    <div class="project-tech">
        {tags.map((tag) => <span class="tech-tag">{tag}</span>)}
    </div>
</div>

<style>
    .project {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 12px;
        transition: border-color 0.2s;
    }

    .project:hover {
        border-color: #2a2a2a;
    }

    .project-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 8px;
    }

    .project-name {
        font-weight: 600;
        font-size: 1.05em;
    }

    .project-name a {
        color: var(--text);
        text-decoration: none;
    }

    .project-name a:hover {
        color: var(--accent);
    }

    .badge {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7em;
        padding: 3px 8px;
        border-radius: 4px;
        font-weight: 500;
    }

    .badge-live {
        background: rgba(34, 197, 94, 0.1);
        color: var(--green);
        border: 1px solid rgba(34, 197, 94, 0.2);
    }

    .badge-oss {
        background: rgba(59, 130, 246, 0.1);
        color: var(--accent);
        border: 1px solid rgba(59, 130, 246, 0.2);
    }

    .project-desc {
        color: var(--text-dim);
        font-size: 0.9em;
        line-height: 1.5;
        margin-bottom: 12px;
    }

    .project-tech {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .tech-tag {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7em;
        color: var(--text-dim);
        background: rgba(10, 14, 23, 0.8);
        padding: 2px 8px;
        border-radius: 3px;
        border: 1px solid var(--border);
    }
</style>
